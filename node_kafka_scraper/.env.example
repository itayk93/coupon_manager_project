# Kafka configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP=coupon-scraper-group
KAFKA_TOPIC=coupon-auto-updates

# Supabase credentials (service role has write access to coupon tables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Selenium / browser grid
SELENIUM_REMOTE_URL=http://localhost:4444/wd/hub
SELENIUM_BROWSER=chrome
SELENIUM_TIMEOUT=30000
SCRAPER_HEADLESS=true
SCRAPER_WAIT_MS=2000

# Cron and scraper defaults
CRON_FETCH_LIMIT=250
CRON_SCHEDULE=0 4 * * *
JOB_MAX_RETRIES=3
